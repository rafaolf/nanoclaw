# ─── Authentication (one of these is required) ───────────────────────────────
# Anthropic API key (direct API access)
ANTHROPIC_API_KEY=
# OR OAuth token (from Claude Code login — used automatically if no API key)
# CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_AUTH_TOKEN=

# Custom API endpoint (for proxies, local models, or compatible providers)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ─── Assistant ────────────────────────────────────────────────────────────────
# Name used as trigger word (default: Andy). Messages starting with @Name trigger the agent.
ASSISTANT_NAME=Andy
# Set to "true" if the assistant has its own phone number (not sharing yours)
ASSISTANT_HAS_OWN_NUMBER=


# ─── Channel Tokens ──────────────────────────────────────────────────────────
# Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=
# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=
# Slack tokens (from Slack App settings — Socket Mode)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ─── Third-Party Integrations ────────────────────────────────────────────────
# Jira Cloud (available to all groups)
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# HubSpot CRM (scoped to specific groups — see container-runner.ts)
HUBSPOT_ACCESS_TOKEN=

# Google Drive — place google-service-account.json in the project root
# (auto-detected, no env var needed)

# Voice transcription (Groq Whisper — free at console.groq.com)
GROQ_API_KEY=

# ─── Container Runtime ───────────────────────────────────────────────────────
# Docker image name (default: nanoclaw-agent:latest)
# CONTAINER_IMAGE=nanoclaw-agent:latest
# Agent execution timeout in ms (default: 1800000 = 30 min)
# CONTAINER_TIMEOUT=1800000
# Max output size in bytes (default: 10485760 = 10 MB)
# CONTAINER_MAX_OUTPUT_SIZE=10485760
# Credential proxy port (default: 3001)
# CREDENTIAL_PROXY_PORT=3001
# Idle timeout before container is killed, in ms (default: 1800000 = 30 min)
# IDLE_TIMEOUT=1800000
# Max concurrent container instances (default: 5)
# MAX_CONCURRENT_CONTAINERS=5

# ─── Other ────────────────────────────────────────────────────────────────────
# Timezone for scheduled tasks (default: system timezone)
# TZ=America/Sao_Paulo
# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info
